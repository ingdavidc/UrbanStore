# ==========================================
# URBAN 8 STORE — Variables de Entorno
# IMPORTANTE: NO subir este archivo a Git
# ==========================================

# Firebase (obtener en console.firebase.google.com)
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# MercadoPago (obtener en developers.mercadopago.com)
VITE_MP_PUBLIC_KEY=your_mercadopago_public_key

# Addi (obtener en merchants.addi.com)
VITE_ADDI_ALLY_SLUG=your_addi_ally_slug

# Sistecredito (obtener con el equipo de Sistecredito)
VITE_SISTECREDITO_MERCHANT_ID=your_sistecredito_merchant_id

# Meta / Instagram API (obtener en developers.facebook.com)
VITE_META_APP_ID=your_meta_app_id
VITE_META_ACCESS_TOKEN=your_access_token
